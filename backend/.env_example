# ── Required ──────────────────────────────────────────
DEEPGRAM_API_KEY=your_deepgram_api_key
GOOGLE_API_KEY=your_google_api_key

# ── Optional API Keys ─────────────────────────────────
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
HF_TOKEN=

# ── Model Selection ───────────────────────────────────
SPEAKER_REPAIR_PRIMARY_MODEL=gpt-4o-mini
SPEAKER_REPAIR_MODEL=gemini-2.5-flash
ANALYSIS_MODEL=gemini-2.5-flash
DEEPGRAM_MODEL=nova-3
DEEPGRAM_DIARIZE_MODEL=latest

# ── WhisperX ──────────────────────────────────────────
WHISPERX_MODEL=small
WHISPERX_BATCH_SIZE=1
WHISPERX_COMPUTE_TYPE=int8

# ── Server ────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
APP_ENV=development

# ── Database ──────────────────────────────────────────
DATABASE_URL=postgresql://fitnova:fitnova_dev@localhost:5432/fitnova

# ── Application ───────────────────────────────────────
DEFAULT_ORG_ID=11111111-1111-1111-1111-111111111111
MIN_DURATION_SEC=10
QUOTE_MATCH_THRESHOLD=0.6

# ── Retry Settings ────────────────────────────────────
DEEPGRAM_MAX_RETRIES=3
GEMINI_MAX_RETRIES=2
RETRY_BASE_DELAY_MS=1000

# ── Versioning ────────────────────────────────────────
RUBRIC_VERSION=1.0
COMPANY_FACTS_VERSION=1.0
ANALYSIS_VERSION=1.0

# ── Dev Log Flags ─────────────────────────────────────
LOG_SENSITIVE_DETAILS=true
LOG_TRACEBACKS=true
LOG_VALIDATION_PAYLOADS=true
LOG_FILE_METADATA=true
